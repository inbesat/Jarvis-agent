# ============================================================
# JARVIS .env Configuration
# Copy this file to .env and fill in your API keys
# ============================================================
# REQUIRED — Without these, Jarvis will not work
# ============================================================

# Groq (fast inference, free tier available)
# Get key at: https://console.groq.com
GROQ_API_KEY=_groq_api_key_

# OpenRouter (backup inference + vision models)
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=_openrouter_api_key_

# ============================================================
# OPTIONAL — Backup keys for fallback chain
# ============================================================

# Backup Groq key (used when primary fails)
GROQ_API_KEY_BACKUP=_groq_api_key_backup_

# Backup OpenRouter key (used when primary fails)
OPENROUTER_API_KEY_BACKUP=_openrouter_api_key_backup_

# ============================================================
# OPTIONAL — Web Search & Weather
# ============================================================

# SerpAPI (Google search results)
# Free tier: 100 searches/month
# Get key at: https://serpapi.com
SERPAPI_API_KEY=_serpapi_api_key_

# OpenWeather (weather data)
# Free tier: 1000 calls/day
# Get key at: https://openweathermap.org
OPENWEATHER_API_KEY=_openweather_api_key_

# ============================================================
# OPTIONAL — News & Information
# ============================================================

# NewsData.io (news headlines)
# Free tier: 200 credits/day
# Get key at: https://newsdata.io
NEWSDATA_API_KEY=_newsdata_api_key_

# NASA API (picture of the day)
# Free tier: 1000 requests/hour
# Get key at: https://api.nasa.gov
NASA_API_KEY=_nasa_api_key_

# ============================================================
# OPTIONAL — Countries & Facts
# ============================================================

# REST Countries API
# Free tier: unlimited
# Get key at: https://restcountries.com
REST_COUNTRIES_API_KEY=_rest_countries_api_key_

# ============================================================
# OPTIONAL — Notes & Knowledge
# ============================================================

# Notion integration
# Get token at: https://notion.so/my-integrations
NOTION_TOKEN=_notion_token_
NOTION_DATABASE_ID=_notion_database_id_

# ============================================================
# OPTIONAL — AnythingLLM (local RAG)
# ============================================================

# AnythingLLM (run locally at localhost:3001)
ANYTHING_API_KEY=_anything_api_key_
WORKSPACE_SLUG=jarvis
ANYTHING_API_URL=http://localhost:3001/api/v1/workspace/jarvis/chat

# ============================================================
# OPTIONAL — HuggingFace (local embeddings)
# ============================================================

HF_TOKEN=_hf_token_
